# Trabecc Cloud — environment variables
# Copy to .env for local dev. In production these are set in the Vercel
# project's environment-variables UI.

# Neon Postgres connection string. Get one free at https://neon.tech
# Format: postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
DATABASE_URL=postgres://user:password@localhost:5432/trabecc_cloud

# HTTP server port for local dev (Vercel sets this in production).
PORT=8787

# Optional: secret used to encrypt admin tokens. 32+ random chars.
# Generate via: node -e 'console.log(crypto.randomBytes(32).toString("hex"))'
ADMIN_SECRET=changeme-please

# Optional: Trabecc Cloud public URL — used in dashboard links + emails
# (you'll set this to https://api.trabecc.com once deployed).
PUBLIC_URL=http://localhost:8787

# Stripe (left blank for v0 — wired up in v0.3 when we automate provisioning)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
